releases:
  - name: custom-alert-rules
    namespace: monitoring
    chart: ../charts/raw
    installed: true
    values:

      - globalLabels:
          app.kubernetes.io/part-of: platform-observability
          sws.io/team: platform-engineering
        resources:
          {{- range $doc := splitList "---" (readFile "../alerts/infrastructure.yaml") }}
          {{- $parsed := fromYaml $doc }}
          {{- if $parsed }}
          - {{ toYaml $parsed | nindent 12 | trim }}
          {{- end }}
          {{- end }}
          {{- range $doc := splitList "---" (readFile "../alerts/middleware.yaml") }}
          {{- $parsed := fromYaml $doc }}
          {{- if $parsed }}
          - {{ toYaml $parsed | nindent 12 | trim }}
          {{- end }}
          {{- end }}
          {{- range $doc := splitList "---" (readFile "../alerts/applications.yaml") }}
          {{- $parsed := fromYaml $doc }}
          {{- if $parsed }}
          - {{ toYaml $parsed | nindent 12 | trim }}
          {{- end }}
          {{- end }}
